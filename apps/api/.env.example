# Server
PORT=3001
FRONTEND_URL=http://localhost:3100

# Database
# Connection limit is explicitly set to 10 for connection pooling optimization in our single-node setup.
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/task_tracker?schema=public&connection_limit=10"

# Redis
REDIS_URL="redis://localhost:6380"

# MinIO
MINIO_ENDPOINT="localhost"
MINIO_PORT=9010
MINIO_ROOT_USER="your-minio-user"
MINIO_ROOT_PASSWORD="your-minio-password"
MINIO_ACCESS_KEY="your-minio-user"
MINIO_SECRET_KEY="your-minio-password"

# JWT
JWT_SECRET="supersecret_jwt_key"
JWT_REFRESH_SECRET="supersecret_refresh_key"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Notifications
SMTP_HOST="smtp.ethereal.email"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@tasktracker.com"
# Generate a fresh pair with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"

# SAML SSO (Sprint 18) — Task Tracker acts as the Service Provider.
# The IdP certificate is the ONLY trust channel with Crate.
SAML_ACS_URL="http://localhost:3001/auth/saml/acs"
SAML_SP_AUDIENCE="task-tracker"
SAML_IDP_ENTRY_POINT="http://localhost:3000/apps/REPLACE_WITH_APP_ID/sso"
# Preferred: path to Crate's public cert, exported from GET /apps/:id/metadata.
SAML_IDP_CERT_PATH="./crate-idp.pem"
# Alternative to the path above: inline PEM with \n escapes.
# SAML_IDP_CERT=""
